# Public URL of the deployed FastAPI backend, NO trailing slash.
# Example (Render): https://celltwin-api.onrender.com
#
# Local dev: leave this UNSET — the Vite dev server proxies /api to
# http://localhost:8000 (see vite.config.ts), so `npm run dev` just works.
#
# Vercel: set VITE_API_BASE in Project Settings -> Environment Variables to your
# backend URL, then redeploy.
VITE_API_BASE=https://celltwin-api.onrender.com
